# Water-stress ML model service (Random Forest classifier)
# Loads the persisted rf-model.pkl and serves /predict endpoint.
# Uses Python 3.11+ so scikit-learn 1.7.x (matching the trained model) is available.
FROM python:3.11-slim
WORKDIR /app
COPY model_service.py .
RUN pip install Werkzeug==2.3.6 joblib==1.3.1 Flask==2.0.2 gunicorn==20.1.0 scikit-learn==1.7.2
COPY rf-model.pkl data/
CMD ["gunicorn", "-w 4", "-b", "0.0.0.0:8000", "model_service:app"]
